    "tools": true,
    "vision": true,
    "streaming": true
  },
  "fallbacks": [
    {
      "model": "openrouter/nvidia/nemotron-3-super",
      "apiUrl": "http://127.0.0.1:4182"
    },
    {
      "model": "groq/llama-3.3-70b-versatile",
      "apiUrl": "http://127.0.0.1:4182"
    },
    {
      "model": "gemini/gemini-2.5-flash",
      "apiUrl": "http://127.0.0.1:4182"
    }
  ]
}
