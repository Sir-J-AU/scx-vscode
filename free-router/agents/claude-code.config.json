{
  "$comment": "Claude Code configuration for Kritical Free Router (OpenRouter + free providers)",
  "model": "openrouter/free",
  "apiUrl": "http://127.0.0.1:4182",
  "apiKey": "sk-kritical-free-local",
  "headers": {
    "HTTP-Referer": "https://kritical.net",
    "X-Title": "Kritical Claude Code"
  },
  "maxTokens": 8192,
